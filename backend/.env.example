# === 运行模式 ===
DEMO_MODE=true

# === Anthropic Claude（全部留「副模型」空则与主模型同一旗舰）===
ANTHROPIC_API_KEY=sk-ant-xxx
# 第三方 anthropic-compatible 中转 (OneAPI / 学钉 token 等); 留空 → 走官方 api.anthropic.com
# SDK 会在此 URL 后自动补 /v1/messages, base_url 一般填到域名层级
ANTHROPIC_BASE_URL=
# 兜底默认；任何 purpose 没专属配置时用
ANTHROPIC_MODEL=claude-opus-4-7
# V1 ModelRouter per-purpose 模型（空 → 走 ANTHROPIC_MODEL）
# 推荐：编排/澄清 sonnet（强且便宜），意图 haiku（快），T 主体 opus（写作），vision opus
ANTHROPIC_MODEL_CONDUCTOR=
ANTHROPIC_MODEL_INTENT=
ANTHROPIC_MODEL_T=
ANTHROPIC_MODEL_VISION=
# 旧 per-role 字段（PR #9）：T agent / V0 角色聊天仍用，保留向后兼容
ANTHROPIC_MODEL_CAPABILITY_TEXT=
ANTHROPIC_MODEL_ROLE_CHAT=
ANTHROPIC_MAX_OUTPUT_TOKENS_CAPABILITY_TEXT=8192
ANTHROPIC_MAX_OUTPUT_TOKENS_ROLE_CHAT=4096

# === 必填：DeepSeek（中文文本 / 兜底）===
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# PRO 默认 deepseek-chat：reasoner 在结构化 JSON 输出上常被截断（已通过 verify_deepseek 验证）
DEEPSEEK_MODEL_PRO=deepseek-chat
# FLASH：预留快路径 · 通常为 chat/v4-flash 路由（以官网为准）
DEEPSEEK_MODEL_FLASH=deepseek-chat
# 显式推理路径（conductor 备选）
DEEPSEEK_MODEL_REASONER=deepseek-reasoner
DEEPSEEK_MAX_OUTPUT_TOKENS=8192

# === 必填：图像生成（SiliconFlow）===
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
# 画质优先默认 FLUX.2-pro；要快/省钱可改 black-forest-labs/FLUX.1-schnell（注意下方尺寸枚举不同）
IMAGE_MODEL=black-forest-labs/FLUX.2-pro
# FLUX.2 仅支持：512x512、768x1024、1024x768、576x1024（竖屏短视频）、1024x576（横屏）
IMAGE_SIZE=768x1024
# FLUX.1-dev（1–30）/ FLUX.2-flex（1–50）步数；其它模型可忽略
IMAGE_INFERENCE_STEPS=28
IMAGE_GENERATION_TIMEOUT=180

# === 必填：TTS ===
MINIMAX_API_KEY=xxx
MINIMAX_GROUP_ID=xxx
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=male-qn-jingying

# === 可选：T agent 工具（V1 ReAct）===
# Tavily 搜索 API，让 T agent 真正能"查"。无 key 时 web_search 走占位 fixture。
TAVILY_API_KEY=

# === 可选 ===
LOG_LEVEL=INFO
ARTIFACT_DIR=./data/artifacts
UPLOAD_DIR=./data/uploads
CHECKPOINT_PATH=./data/checkpoints/checkpoints.db
CORS_ORIGIN=http://localhost:3000
DEFAULT_BGM_PATH=./assets/bgm/default_warning.mp3
