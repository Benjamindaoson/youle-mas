# 前端连本机后端（复制为 .env.local 后按需修改；pnpm dev 下可不填，默认连 http://127.0.0.1:8001）
NEXT_PUBLIC_AGENT_SERVER_URL=http://127.0.0.1:8001

# Next rewrites() 同源代理目标 — 与本机 uvicorn --port 保持一致
YOULE_BACKEND_INTERNAL_URL=http://127.0.0.1:8001

# 仅在 pnpm dev 想强制前端纯 mock、连默认后端也不要
# NEXT_PUBLIC_AGENT_MOCK_ONLY=1

# 可选：NEXT_PUBLIC_AGENT_SERVER_PROXY=false   # 浏览器直连后端（调 CORS / 调试）
# 可选：NEXT_PUBLIC_AGENT_SERVER_URL=/api/youle-backend   # 显式只做同源前缀
